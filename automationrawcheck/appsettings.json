{
  // ============================================================
  // appsettings.json - 건축/토지 법규 검토 백엔드 설정 파일
  // ============================================================

  // ── 공간 데이터 디렉토리 설정 ──────────────────────────────────
  // ZoningShapefileDirectory: SHP 파일들이 있는 최상위 폴더 경로
  // 하위 디렉토리를 재귀 탐색하여 모든 .shp 파일을 자동 로드합니다.
  //
  // [디렉토리 구조 예시]
  //   data/shp/
  //     UPIS_004_20260201_11000/  ← 서울 용도지역
  //       UPIS_C_UQ111.shp        ← 제1종일반주거지역 등
  //       UPIS_C_UQ122.shp
  //     KLIP_004_20260201_41000/  ← 경기 용도지역
  //       KLIP_C_UQ111.shp
  //
  // [실제 DBF 컬럼]
  //   DGM_NM  : 용도지역명 (EUC-KR, 예: "제2종일반주거지역")
  //   ATRB_SE : 속성구분코드 (예: "UQA122")
  //   좌표계  : EPSG:5174 (Korean 1985 / Modified Central Belt TM)
  "SpatialData": {
    "ZoningShapefileDirectory": "C:/Users/User/Desktop/programing/automationrawcheck/data/shp",
    "CityPlanShapefileDirectory": "C:/Users/User/Desktop/programing/automationrawcheck/city plan data/shp",
    "CityPlanCsvDirectory": "C:/Users/User/Desktop/programing/automationrawcheck/city plan data/csv"
  },

  // ── 법령 API 설정 ──────────────────────────────────────────────
  // Enabled:         기존 ILawReferenceProvider (zoningCode 기반) 활성화
  // ClauseEnabled:   ILawClauseProvider (normalizedKey 기반 조문 조회) 활성화
  // OcValue:         법제처 DRF API OC 파라미터 (인증 식별자)
  //                  ★ 운영 환경에서는 환경변수로 주입하세요:
  //                    환경변수: LawApi__OcValue=<인증키>
  //                    dotnet user-secrets: LawApi:OcValue=<인증키>
  //                  ★ 아래 OcValue/ServiceKey는 개발 편의용 — 프로덕션 빌드 전 반드시 제거
  // MaxRetries:       HTTP 재시도 횟수 (0=없음, 기본 1)
  // MaxClausesPerItem: 응답 항목당 최대 조문 수 (기본 10)
  // ClauseMaxLength:  조문 텍스트 최대 글자 수 (기본 500)
  "LawApi": {
    "Enabled": false,
    "ClauseEnabled": true,
    "OcValue": "",
    "ServiceKey": "",
    "BaseUrl": "http://www.law.go.kr/DRF",
    "TimeoutSeconds": 10,
    "MaxRetries": 1,
    "MaxClausesPerItem": 10,
    "ClauseMaxLength": 500,
    "TermSearchUrl": "https://open.law.go.kr/LSW/lawTermInfoR.do"
  },

  // ── V-World 공간정보 오픈플랫폼 설정 ──────────────────────────────
  // ApiKey: https://www.vworld.kr 회원가입 후 무료 발급
  // DistrictUnitPlanLayer: GetCapabilities로 실제 레이어명 확인 필요
  //   확인 URL: https://api.vworld.kr/req/wfs?SERVICE=WFS&REQUEST=GetCapabilities&KEY={key}
  "VWorld": {
    "ApiKey": "B100839C-BE7A-3FB8-BA44-77D1ABC1CD4B",
    "DataBaseUrl": "https://api.vworld.kr/req/data",
    "GeocodingBaseUrl": "https://api.vworld.kr/req/address",
    "DistrictUnitPlanLayer": "LT_C_UPISUQ161",
    "TimeoutSeconds": 5
  },

  // ── 주소 검색 API 설정 (현재 stub - 향후 활성화) ────────────────
  "DevelopmentActionPermitApi": {
    "Enabled": false,
    "BaseUrl": "",
    "RequestPath": "",
    "UserId": "",
    "ServiceKey": "",
    "TimeoutSeconds": 5,
    "LongitudeParameterName": "lon",
    "LatitudeParameterName": "lat",
    "UserIdParameterName": "id",
    "ServiceKeyParameterName": "key",
    "StaticQueryParameters": {},
    "RequestHeaders": {},
    "ResponseRootPath": "",
    "InsideFieldPath": "",
    "NameFieldPath": "",
    "CodeFieldPath": ""
  },
  "ReviewSnapshotStore": {
    "Enabled": true,
    "StoragePath": "App_Data/review-snapshots.json",
    "WriteIndented": true
  },
  "AiAssist": {
    "Enabled": false,
    "Provider": "gemma4",
    "Model": "gemma4",
    "ExecutionMode": "preview",
    "Endpoint": "",
    "ApiKey": "",
    "ApiKeyHeaderName": "Authorization",
    "ApiKeyPrefix": "Bearer",
    "SystemInstruction": "You are Gemma4 acting as a legal navigation assistant. Never decide pass/fail, permitted/prohibited use, or compute legal thresholds. Return structured JSON only."
  },
  "RegulationResearch": {
    "LiveLawSourceEndpoint": "",
    "MunicipalOrdinanceEndpoint": "",
    "PdfHubEndpoint": "",
    "ChangeTrackingMode": "manual_compare",
    "SearchHubMode": "metadata_composition"
  },

  "AddressApi": {
    "Provider": "None",
    "VWorldApiKey": "",
    "KakaoRestApiKey": "",
    "TimeoutSeconds": 5
  },

  // ── Serilog 로깅 설정 ──────────────────────────────────────────
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },

  "AllowedHosts": "*"
}
